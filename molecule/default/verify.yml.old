- name: Verify
  become: true
  hosts: all
  gather_facts: true
  tasks:
    - name: Check if systemd-resolved is running
      command: systemctl is-active systemd-resolved
      register: resolved_status
      changed_when: false
      failed_when: false

    - name: Determine DNS configuration method
      set_fact:
        use_systemd_resolved: "{{ resolved_status.rc == 0 and resolved_status.stdout == 'active' }}"

    - name: Get DNS configuration from systemd-resolved
      command: resolvectl status
      register: resolved_output
      when: use_systemd_resolved

    - name: Debug resolved_output
      debug:
        var: resolved_output.stdout
      when: use_systemd_resolved

    - name: Extract only Global DNS Servers lines
      set_fact:
        dns_servers_lines: >-
          {{
            resolved_output.stdout.splitlines()
            | select("search", "DNS Servers:")
            | reject("search", "Fallback DNS Servers:")
            | reject("search", "Link")
            | list
          }}
      when: use_systemd_resolved

    - name: Debug dns_servers_lines
      debug:
        var: dns_servers_lines
      when: use_systemd_resolved

    - name: Debug cleaned DNS Servers lines
      set_fact:
        cleaned_dns_servers_lines: >-
          {{
            dns_servers_lines
            | map("regex_replace", "^\\s*DNS Servers:\\s*", "")
            | map("trim")
            | list
          }}
      when: use_systemd_resolved

    - name: Debug cleaned_dns_servers_lines
      debug:
        var: cleaned_dns_servers_lines
      when: use_systemd_resolved

    - name: Parse individual DNS servers
      set_fact:
        resolved_dns_servers: >-
          {{
            cleaned_dns_servers_lines
            | map("split", " ")
            | flatten
            | select("match", "^(\\d+\\.\\d+\\.\\d+\\.\\d+)$")
            | unique
          }}
      when: use_systemd_resolved

    - name: Debug resolved_dns_servers
      debug:
        var: resolved_dns_servers

    - name: Debug dns_servers
      debug:
        var: dns_servers

    - name: Get DNS configuration from /etc/resolv.conf
      command: cat /etc/resolv.conf
      register: resolv_conf_output
      when: not use_systemd_resolved

    - name: Debug resolv_conf_output
      debug:
        var: resolv_conf_output.stdout
      when: not use_systemd_resolved

    - name: Parse DNS servers and domains from /etc/resolv.conf
      set_fact:
        resolved_dns_servers: "{{ resolv_conf_output.stdout | regex_findall('nameserver\\s+(\\S+)') | unique }}"
        resolved_dns_domains: "{{ resolv_conf_output.stdout | regex_findall('search\\s+(.*)') | first | default('') | split(' ') if 'search' in resolv_conf_output.stdout else [] }}"
      when: not use_systemd_resolved

    - name: Assert DNS servers are as expected
      assert:
        that:
          - "resolved_dns_servers | sort == dns_servers | sort"
        fail_msg: "DNS servers do not match the expected configuration"
        success_msg: "DNS servers are correctly configured"

    - name: Assert DNS domains are as expected
      assert:
        that:
          - "resolved_dns_domains | sort == dns_domains | sort"
        fail_msg: "DNS search domains do not match the expected configuration"
        success_msg: "DNS search domains are correctly configured"
